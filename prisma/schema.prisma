generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipType {
  BRONCE
  PLATA
  ORO
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

model Member {
  id             String     @id @default(cuid())
  name           String
  email          String     @unique
  membershipType MembershipType
  status         Boolean    @default(true)
  dietPlan       String?
  payments       Payment[]
  bookings       Booking[]
  createdAt      DateTime   @default(now())
}

model Payment {
  id         String        @id @default(cuid())
  member     Member        @relation(fields: [memberId], references: [id])
  memberId   String
  amount     Float
  currency   String        @default("USD")
  status     PaymentStatus @default(PENDING)
  createdAt  DateTime      @default(now())
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Float
  stock       Int
  image       String?
  createdAt   DateTime @default(now())
}

model Class {
  id          String    @id @default(cuid())
  title       String
  instructor  String
  startTime   DateTime
  capacity    Int
  bookedCount Int       @default(0)
  bookings     Booking[]
  createdAt   DateTime  @default(now())
}

model Booking {
  id        String   @id @default(cuid())
  member    Member   @relation(fields: [memberId], references: [id])
  memberId  String
  class     Class    @relation(fields: [classId], references: [id])
  classId   String
  createdAt DateTime @default(now())
}
